# ─────────────────────────────────────────────────────────────────────────────
# FitTrack App — Variabili d'Ambiente
# Copia questo file in .env e inserisci i tuoi valori reali.
# IMPORTANTE: Non committare mai il file .env nel repository!
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (Fase 1 — Database)
# Ottienile da: https://app.supabase.com → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI (Fase 6 — AI Engine per varianti esercizi)
# Ottieni la chiave da: https://platform.openai.com/api-keys
# Il prefisso EXPO_PUBLIC_ la rende accessibile nel bundle client-side
# ATTENZIONE: in produzione usa un backend proxy per proteggere la chiave!
EXPO_PUBLIC_OPENAI_KEY=sk-proj-your-openai-key-here
